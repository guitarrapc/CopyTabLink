{
  "manifest_version": 3,
  "name": "CopyTabLink Copy",
  "short_name": "CopyTabLink",
  "version": "0.1.0",
  "description": "Copy the current page title and URL.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "offscreen",
    "clipboardWrite",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "copy-plain": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Command+Shift+C"
      },
      "description": "Copy current page as plain text"
    },
    "copy-markdown": {
      "suggested_key": {
        "default": "Alt+M",
        "mac": "Command+Shift+M"
      },
      "description": "Copy current page as markdown link"
    }
  },
  "action": {
    "default_title": "Copy Page Info"
  }
}
