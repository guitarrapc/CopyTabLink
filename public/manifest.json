{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "short_name": "CopyTabLink",
  "version": "0.9.1",
  "description": "__MSG_extDescription__",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "offscreen",
    "clipboardWrite",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "copy-plain": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Command+Shift+C"
      },
      "description": "__MSG_commandCopyPlain__"
    },
    "copy-markdown": {
      "suggested_key": {
        "default": "Alt+M",
        "mac": "Command+Shift+M"
      },
      "description": "__MSG_commandCopyMarkdown__"
    }
  },
  "action": {
    "default_title": "__MSG_actionDefaultTitle__"
  }
}
